# ゆうき整骨院 yuuki-rehab 環境変数の例（実キーは .env.local に置く。Git管理しない）

# AI生成（必須）
ANTHROPIC_API_KEY=

# マーケティングハブ動作モード: mock | live（未設定はliveだがキーが無ければ自動的にmock）
MARKETING_MODE=mock

# 画像生成（Phase 1後半〜）
OPENAI_API_KEY=

# LINE Messaging API（Phase 2）
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# 計測リンクの生成に使うアプリ自身のURL（本番: https://yuuki-rehab.vercel.app）
APP_URL=

# LINE本番運用時の二重返信対策: off にすると自由テキストへのメニュー再提示を止め、
# 既存の応答メッセージ（キーワード自動応答）と共存できる（緊急判定・引き継ぎは常に有効）
LINE_TEXT_FALLBACK=

# Supabase（本番のLINE顧客データ保存。未設定ならローカルファイル保存）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 本番の管理画面保護（Vercelに設定。ローカルは未設定=保護なしでOK）
MARKETING_ADMIN_PASSWORD=

# ジョブ実行の保護（Vercel Cron / GitHub Actions と共有）
CRON_SECRET=

# Instagram自動投稿（docs/marketing-hub/INSTAGRAM-SETUP.md）
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# 予約→院長LINE通知（docs/marketing-hub/RESERVATION-LINE-NOTIFY-SETUP.md）
# RESERVATION_NOTIFY_SECRET: GAS予約システムと共有する合言葉
# RESERVATION_NOTIFY_LINE_USER_ID: 通知先（院長）のLINE userId
# LINE_WHOAMI_KEYWORD: userId取得用の一時キーワード（設定時のみ有効）
RESERVATION_NOTIFY_SECRET=
RESERVATION_NOTIFY_LINE_USER_ID=
LINE_WHOAMI_KEYWORD=
